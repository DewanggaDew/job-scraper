# ============================================================
#  Job Scraper — Environment Variables
#  Copy to .env and fill in your values. .env is gitignored.
# ============================================================

# ── Supabase (required) ─────────────────────────────────────────────────────
# Dashboard → Project Settings → API
# Use the service_role secret key here (server-side; not the anon browser key).

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-here

# ── Email notifications (optional — omit to skip Resend emails) ────────────────
# https://resend.com/api-keys

RESEND_API_KEY=
NOTIFY_EMAIL=
DASHBOARD_URL=https://your-dashboard.vercel.app

# ── LinkedIn (optional — needed for LinkedIn scraper to return jobs) ─────────
# Or set LINKEDIN_COOKIES to a JSON array of Playwright cookies instead.

LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
# LINKEDIN_COOKIES=[{"name":"li_at","value":"...","domain":".linkedin.com",...}]

# ── Model cache (optional) ───────────────────────────────────────────────────
# SENTENCE_TRANSFORMERS_HOME=D:/Projects/job-scraper/scraper/.cache/sentence-transformers
